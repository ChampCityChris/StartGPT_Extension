{
  "name": "startgpt-sidebar",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Firefox extension scaffold for Startpage + ChatGPT Sidebar.",
  "scripts": {
    "dev": "web-ext run -c web-ext.config.mjs",
    "lint": "node scripts/lint.mjs",
    "check:secrets": "node scripts/check-secrets.mjs",
    "check:security": "node scripts/check-security-boundaries.mjs",
    "playwright": "node scripts/run-playwright.cjs",
    "playwright:install": "node scripts/run-playwright.cjs install firefox",
    "playwright:list": "node scripts/run-playwright.cjs install --list",
    "test": "node scripts/check-secrets.mjs && node scripts/check-security-boundaries.mjs && node scripts/run-vitest.cjs run",
    "build": "node scripts/pack.mjs"
  },
  "devDependencies": {
    "jsdom": "^26.1.0",
    "playwright": "^1.58.2",
    "vitest": "^3.2.4",
    "web-ext": "^8.8.0"
  }
}
