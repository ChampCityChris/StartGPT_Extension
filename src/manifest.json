{
  "manifest_version": 3,
  "name": "StartGPT Sidebar",
  "description": "Startpage summarizer with browser-only BYOK OpenAI API calls.",
  "version": "0.2.0",
  "action": {
    "default_title": "StartGPT Sidebar",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "scripts": ["background/background.js"],
    "type": "module"
  },
  "sidebar_action": {
    "default_title": "StartGPT Sidebar",
    "default_panel": "sidebar/unavailable.html"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://startpage.com/*",
    "https://*.startpage.com/*",
    "https://api.openai.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://startpage.com/*",
        "https://*.startpage.com/*"
      ],
      "js": ["content/startpage-loader.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content/startpage.js",
        "content/dom/*.js",
        "content/inject/*.js",
        "content/shared/*.js"
      ],
      "matches": [
        "https://startpage.com/*",
        "https://*.startpage.com/*"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'none'"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "startgpt-sidebar@example.local"
    }
  }
}
