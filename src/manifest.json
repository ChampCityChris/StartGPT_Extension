{
  "manifest_version": 3,
  "name": "StartGPT",
  "description": "Startpage summarizer with browser-only BYOK OpenAI API calls.",
  "version": "0.2.0",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png"
    },
    "default_title": "StartGPT",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "scripts": ["background/background.js"],
    "type": "module"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://startpage.com/*",
    "https://*.startpage.com/*",
    "https://api.openai.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://startpage.com/*",
        "https://*.startpage.com/*"
      ],
      "js": ["content/startpage-loader.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content/startpage.js",
        "content/dom/*.js",
        "content/inject/*.js",
        "content/shared/*.js"
      ],
      "matches": [
        "https://startpage.com/*",
        "https://*.startpage.com/*"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'none'"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "startgpt@example.local"
    }
  }
}
